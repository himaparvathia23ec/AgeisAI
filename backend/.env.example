# Google OAuth2 Credentials
# Get these from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# OAuth Redirect URI (must match Google Cloud Console exactly)
# Backend callback - Google redirects here with ?code=
OAUTH_REDIRECT_URI=http://127.0.0.1:8000/auth/gmail/callback

# CORS Origins (comma-separated) - frontend origin
CORS_ORIGINS=http://localhost:3000
# For production:
# CORS_ORIGINS=https://yourdomain.com
